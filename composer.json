{
    "name": "sqrd/page-cache",
    "description": "Accept-aware nginx-served WordPress page cache.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "sqrd\\Cache\\": "src/"
        }
    },
    "scripts": {
        "test": "pest --no-coverage",
        "test:coverage": "pest --coverage"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "brain/monkey": "*",
        "pestphp/pest": "*"
    }
}
